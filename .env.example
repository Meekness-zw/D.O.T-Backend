# ==============================
# Supabase Configuration
# ==============================

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ==============================
# Twilio Verify (send & verify codes)
# ==============================

TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid_here
TWILIO_PHONE_NUMBER=+1234567890

# ==============================
# Pesepay Payment Gateway
# ==============================

PAYMENT_INTEGRATION_ID=your_pesepay_integration_id_here
PAYMENT_ENCRYPTION_KEY=your_pesepay_encryption_key_here

# ==============================
# Help & support (merchant app — GET /merchant/help)
# ==============================

SUPPORT_PHONE=+263771234567
SUPPORT_EMAIL=support@example.com
# Optional: WhatsApp chat link, e.g. https://wa.me/263771234567
SUPPORT_WHATSAPP_URL=
SUPPORT_HOURS=Mon–Fri 8:00–18:00

# ==============================
# Server Configuration
# ==============================

PORT=4000
NODE_ENV=development

# ==============================
# CORS (comma-separated)
# ==============================

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# ==============================
# Admin Dashboard API key
# ==============================

ADMIN_API_KEY=your_long_random_admin_api_key_here